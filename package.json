    "@fastify/rate-limit": "^9.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^5.1.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "openid-client": "^5.6.5",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
